# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"

# Microsoft 365 / Azure — needed for "Sign in with Microsoft", OneDrive, and Outlook Calendar.
# Register an app at https://portal.azure.com → Microsoft Entra ID → App registrations.
# Set redirect URI to: https://<your-project-ref>.supabase.co/auth/v1/callback
# Required API permissions: Files.ReadWrite, Calendars.ReadWrite, offline_access
# Then add the client ID + secret in Supabase Dashboard → Auth → Providers → Azure.
VITE_AZURE_CLIENT_ID=

# Azure AD app registration (server-side only — Supabase Edge Function secrets)
# Same app as VITE_AZURE_CLIENT_ID; secret never goes in the frontend bundle.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Google AI (Gemini) — used by all edge functions for LLM inference.
# Get your key at: https://aistudio.google.com/apikey (free tier available)
# Add to Supabase: Dashboard → Edge Functions → Secrets → GOOGLE_AI_API_KEY
GOOGLE_AI_API_KEY=

# Dodo Payments — product IDs for each subscription plan.
# Create products in your Dodo Payments dashboard and paste the IDs here.
# Add these as secrets in Supabase: Dashboard → Edge Functions → Secrets
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_PROFESSIONAL=
DODO_PRODUCT_ID_FIRM=
